pipeline {
    agent any 

    stages {
        stage('Fetch Code') {
            steps {
                echo 'Checking out code from GitHub...'
                // Code is automatically fetched into the workspace by Jenkins
               // sh 'ls -la'
            }
        }

        stage('Deploy Website') {
            steps {
                echo 'Deploying index.html to Apache web directory....'
                
                // Copies index.html directly from the local Jenkins workspace to the Apache folder
                sh 'sudo cp index.html /var/www/html/index.html'
                
                echo 'Deployment finished successfully!'
            }
        }
    }
}